{"file":"_id_-QJQ_S6Bj.js","mappings":";;;;;;;;;;;;;;;;;;;;;;AACA,UAAM,QAAQ;AAEd,UAAM,UAAU,IAAI,KAAK,MAAM,MAAM,QAAQ,GAAG,CAAC;AACjD,UAAM,SAAS,IAAuC,IAAI;AAC1D,UAAM,UAAU,IAAI,KAAK;;;QAgBd,OAAM;AAAA,QAAa,eAAY;AAAA,MAAA,gLAOlBA,MAAA,OAAA,CAAO;UAMlBA,MAAA,OAAA,GAAO;;;;;UACPA,MAAA,MAAA,GAAM;oHACYA,MAAA,MAAA,EAAO,eAAe,eAAc,OAAA,CAAA,CAAA,iBAAA;AAAA;;;;;;;;;;;;;;;;;ICnCxD,OAAM;AAAA,IAAa,eAAY;AAAA;;;;;;;;;;;;;;ACA1C,UAAM,QAAQ,SAAA;AACd,UAAM,UAAS,CAAA,QAAA,SAAA,IAAAC,iBAAA,MAAM,UAAA,CAAU;AAE/B,UAAM,EAAE,MAAM,SAAA,KAAa,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM;AAAA,MAAS,iBAAiB,MAAM,OAAO,EAAE;AAAA;;KAAE;AAE5E,UAAM,gBAAgB,SAAS,MAAM,OAAO,OAAO,aAAa,SAAS,qBAAqB,CAAC;AAC/F,UAAM,WAAW,SAAS,MAAM,OAAO,OAAO,aAAa,SAAS,OAAO,CAAC;;;;;QAIrE,OAAA,EAAA,WAAA,OAAA;AAAA,QAAsB,eAAY;AAAA,MAAA;UACrBD,MAAA,QAAA,GAAQ;0DACcE,eAAAF,MAAA,QAAA,EAAS,KAAK,0BAC9BE,eAAAF,MAAA,QAAA,EAAS,IAAI,OAASE,eAAAF,MAAA,QAAA,EAAS,QAAQ,yEAEtDA,MAAA,QAAA,EAAS,MAAM,eAAc,OAAA,CAAA,cAE5BE,eAAAF,MAAA,QAAA,EAAS,WAAW;YAEAA,MAAA,aAAA,GAAa;;YAAG,OAAOA,MAAA,QAAA,EAAS;AAAA,UAAA;;;;YACzCA,MAAA,QAAA,GAAQ;;;;;;;;;;;;;;;;;;;","names":["_unref","_withAsyncContext","_ssrInterpolate"],"sources":["../../../../components/MortgageCalculator.vue","../../../../components/VideoTour.vue","../../../../pages/property/[id].vue"],"sourcesContent":["<script setup lang=\"ts\">\nconst props = defineProps<{ price: number }>()\n\nconst deposit = ref(Math.round(props.price * 0.2))\nconst result = ref<{ monthlyPayment: number } | null>(null)\nconst loading = ref(false)\n\nasync function calculate() {\n  loading.value = true\n  try {\n    result.value = await $fetch('/api/calculate-mortgage', {\n      method: 'POST',\n      body: { price: props.price, deposit: deposit.value }\n    })\n  } finally {\n    loading.value = false\n  }\n}\n</script>\n\n<template>\n  <section class=\"calculator\" data-testid=\"mortgage-calculator\">\n    <h3>İpotek Hesaplayıcı</h3>\n    <label>\n      Peşinat\n      <input\n        type=\"number\"\n        data-testid=\"calc-deposit\"\n        v-model.number=\"deposit\"\n      />\n    </label>\n    <button class=\"cta-button\" data-testid=\"calc-submit\" @click=\"calculate\">\n      Hesapla\n    </button>\n    <p v-if=\"loading\">Hesaplanıyor…</p>\n    <p v-if=\"result\" data-testid=\"calc-result\">\n      Aylık taksit: <strong>{{ result.monthlyPayment.toLocaleString('tr-TR') }} ₺</strong>\n    </p>\n  </section>\n</template>\n\n<style scoped>\n.calculator {\n  padding: 20px;\n  border-radius: var(--radius, 8px);\n  background: var(--color-surface, #f5f5f5);\n  margin-top: 24px;\n}\n.calculator label {\n  display: block;\n  margin: 12px 0;\n}\n.calculator input {\n  display: block;\n  margin-top: 4px;\n  padding: 8px;\n  width: 100%;\n  max-width: 240px;\n}\n</style>\n","<template>\n  <section class=\"video-tour\" data-testid=\"video-tour\">\n    <h3>Video Turu</h3>\n    <div class=\"video-tour__player\" data-testid=\"video-player\">\n      ▶ Sanal tur oynatılıyor (demo)\n    </div>\n  </section>\n</template>\n\n<style scoped>\n.video-tour {\n  margin-top: 24px;\n}\n.video-tour__player {\n  aspect-ratio: 16 / 9;\n  background: #111;\n  color: #eee;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  border-radius: var(--radius, 8px);\n}\n</style>\n","<script setup lang=\"ts\">\nconst route = useRoute()\nconst tenant = await useTenant()\n\nconst { data: property } = await useFetch(`/api/property/${route.params.id}`)\n\nconst hasCalculator = computed(() => tenant.value?.capabilities.includes('mortgage_calculator'))\nconst hasVideo = computed(() => tenant.value?.capabilities.includes('video'))\n</script>\n\n<template>\n  <div style=\"padding: 32px\" data-testid=\"property-detail-page\">\n    <template v-if=\"property\">\n      <h1 data-testid=\"property-title\">{{ property.title }}</h1>\n      <p class=\"muted\">{{ property.city }} · {{ property.bedrooms }} oda</p>\n      <p class=\"price\" data-testid=\"property-price\">\n        {{ property.price.toLocaleString('tr-TR') }} ₺\n      </p>\n      <p>{{ property.description }}</p>\n\n      <MortgageCalculator v-if=\"hasCalculator\" :price=\"property.price\" />\n      <VideoTour v-if=\"hasVideo\" />\n    </template>\n    <p v-else data-testid=\"not-found\">İlan bulunamadı.</p>\n  </div>\n</template>\n"],"version":3}